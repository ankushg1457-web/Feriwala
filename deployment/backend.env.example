# Backend runtime environment for production server.
# Copy this file to deployment/backend.env and fill real values.

NODE_ENV=production
PORT=3000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<database>?retryWrites=true&w=majority

# PostgreSQL (local on Lightsail VM)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=feriwala_db
PG_USER=feriwala
PG_PASSWORD=change-this-strong-password

# JWT
JWT_SECRET=replace-with-strong-random-secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace-with-strong-random-refresh-secret
JWT_REFRESH_EXPIRES_IN=30d

# Google Maps
GOOGLE_MAPS_API_KEY=replace-with-google-maps-key

# Server / upload
SERVER_URL=https://api.example.com
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads
SOCKET_CORS_ORIGIN=*
