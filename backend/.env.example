# Environment
NODE_ENV=development
PORT=3000

# MongoDB (User Database - Atlas Free)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/feriwala_users?retryWrites=true&w=majority

# PostgreSQL (Products, Orders, History)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=feriwala
PG_USER=postgres
PG_PASSWORD=your_pg_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_change_this
JWT_REFRESH_EXPIRES_IN=30d

# Google Maps API
GOOGLE_MAPS_API_KEY=AIzaSyDKijqkofbXiD1WOkPmW-6CQFEpRuLHCJ4

# AWS Server
SERVER_URL=http://13.233.227.15:3000

# File Upload
